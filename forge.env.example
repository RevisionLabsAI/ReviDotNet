# ReviDotNet.Forge environment — copy to "forge.env" (gitignored) and fill in real keys.
#
# Loaded at startup by DotNetEnv (Program.cs: .AddDotNetEnv("forge.env", LoadOptions.TraversePath())),
# which searches this directory and its ancestors for a file named exactly "forge.env".
#
# Each provider's .rcfg sets `api-key = environment`, which ProviderProfile.Init() resolves to the
# environment variable PROVAPIKEY__<PROVIDER-NAME-UPPERCASE> (dashes/spaces → underscores).
# Provider names come from RConfigs/Providers/*.rcfg ([[general]] name): claude, gemini, openai.

PROVAPIKEY__CLAUDE=sk-ant-...
PROVAPIKEY__GEMINI=AIza...
PROVAPIKEY__OPENAI=sk-...

# Optional: additional on-disk RConfig folders loaded INTO Forge IN ADDITION to its own embedded set.
# "Also load": Forge's own configs load first and always win on a name clash; these only add what's new.
# Each entry is an RConfigs root containing any of the standard subfolders (Providers/, Models/Inference/,
# Models/Embedding/, Prompts/, Agents/, Tools/). Relative paths resolve against the working directory;
# absolute paths are safest.
#
# One folder:
#   REVI_RCONFIG_PATHS=C:/Users/you/Projects/GreatDebate/GreatDebate.Researcher/RConfigs
#
# Multiple folders — either way works (both are combined and de-duplicated):
#   (a) Semicolon-separated on one line. ';' is a FIXED delimiter — the same on Windows, macOS and Linux
#       (it is NOT the OS path separator), so the value is portable:
#         REVI_RCONFIG_PATHS=C:/Users/you/Projects/GreatDebate/GreatDebate.Researcher/RConfigs;../OtherProj/RConfigs
#   (b) Or one folder per line with a numbered suffix:
#         REVI_RCONFIG_PATHS=C:/Users/you/Projects/GreatDebate/GreatDebate.Researcher/RConfigs
#         REVI_RCONFIG_PATHS_2=../OtherProject/RConfigs
#         REVI_RCONFIG_PATHS_3=D:/Shared/RConfigs
#
# (Also accepted, e.g. in appsettings.json: the .NET config-array form Revi__RConfigPaths__0 / __1.)
