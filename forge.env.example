# ReviDotNet.Forge environment — copy to "forge.env" (gitignored) and fill in real keys.
#
# Loaded at startup by DotNetEnv (Program.cs: .AddDotNetEnv("forge.env", LoadOptions.TraversePath())),
# which searches this directory and its ancestors for a file named exactly "forge.env".
#
# Each provider's .rcfg sets `api-key = environment`, which ProviderProfile.Init() resolves to the
# environment variable PROVAPIKEY__<PROVIDER-NAME-UPPERCASE> (dashes/spaces → underscores).
# Provider names come from RConfigs/Providers/*.rcfg ([[general]] name): claude, gemini, openai.

PROVAPIKEY__CLAUDE=sk-ant-...
PROVAPIKEY__GEMINI=AIza...
PROVAPIKEY__OPENAI=sk-...
