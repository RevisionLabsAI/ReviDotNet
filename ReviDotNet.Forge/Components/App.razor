<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0E121B" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    @* Static files aren't fingerprinted (UseStaticFiles, not MapStaticAssets), so a query-string version
       cache-busts the local stylesheets. Bump ?v when app.css / grouped-instance.css change. *@
    <link href="app.css?v=2" rel="stylesheet" />
    <link href="grouped-instance.css?v=2" rel="stylesheet" />
    <HeadOutlet @rendermode="@InteractiveServer" />
    <title>ReviDotNet Forge</title>
</head>

<body>
    <Routes @rendermode="@InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="forge-export.js"></script>
    <script src="grouped-instance.js"></script>
</body>

</html>
