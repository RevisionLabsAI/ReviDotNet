@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">ReviDotNet Forge</MudText>
        <MudSpacer />
        <JobIndicator />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle2" Class="mt-1" Style="opacity: 0.7">Navigation</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>

            <MudNavGroup Title="Prompts" Icon="@Icons.Material.Filled.ListAlt" Expanded="true">
                <MudNavLink Href="/prompts" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.LibraryBooks">
                    Registry
                </MudNavLink>
                <MudNavLink Href="/prompts/new" Icon="@Icons.Material.Filled.AddCircle">
                    Workshop
                </MudNavLink>
                <MudNavLink Href="/test" Icon="@Icons.Material.Filled.PlayArrow">
                    Test Runner
                </MudNavLink>
                <MudNavLink Href="/optimize" Icon="@Icons.Material.Filled.TrendingUp">
                    Optimizer
                </MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Agents" Icon="@Icons.Material.Filled.Hub" Expanded="true">
                <MudNavLink Href="/agents" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.LibraryBooks">
                    Registry
                </MudNavLink>
                <MudNavLink Href="/workshop" Icon="@Icons.Material.Filled.SmartToy">
                    Workshop
                </MudNavLink>
            </MudNavGroup>

            <MudNavLink Href="/models"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Memory">
                Models
            </MudNavLink>

            <MudNavLink Href="/providers"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Cloud">
                Providers
            </MudNavLink>

            <MudDivider Class="my-2" />
            <MudNavLink Href="/observer"
                        Icon="@Icons.Material.Filled.ManageSearch">
                Observer
            </MudNavLink>
            <MudNavLink Href="/usage"
                        Icon="@Icons.Material.Filled.BarChart">
                Usage
            </MudNavLink>
            <MudNavLink Href="/apikeys"
                        Icon="@Icons.Material.Filled.Key">
                API Keys
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
}
