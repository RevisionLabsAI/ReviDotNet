@inherits LayoutComponentBase

<MudThemeProvider Theme="ForgeTheme.Instance" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Default" Class="forge-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <div class="forge-brand ml-2">
            <div class="forge-brand__mark">
                <MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" Size="Size.Small" />
            </div>
            <div class="forge-brand__text">
                <span class="forge-brand__eyebrow">ReviDotNet</span>
                <span class="forge-brand__name">Forge</span>
            </div>
        </div>
        <MudSpacer />
        <JobIndicator />
        <MudTooltip Text="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@ToggleDarkMode" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Class="forge-drawer">
        <MudDrawerHeader Class="forge-drawer__header">
            <MudText Typo="Typo.overline" Color="Color.Secondary">Workspace</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>

            <MudNavLink Href="/observer"
                        Icon="@Icons.Material.Filled.ManageSearch">
                Observer
            </MudNavLink>

            <MudNavGroup Title="Prompts" Icon="@Icons.Material.Filled.ListAlt" Expanded="true">
                <MudNavLink Href="/prompts" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.LibraryBooks">
                    Registry
                </MudNavLink>
                <MudNavLink Href="/prompts/new" Icon="@Icons.Material.Filled.AddCircle">
                    Workshop
                </MudNavLink>
                <MudNavLink Href="/test" Icon="@Icons.Material.Filled.PlayArrow">
                    Test Runner
                </MudNavLink>
                <MudNavLink Href="/optimize" Icon="@Icons.Material.Filled.TrendingUp">
                    Optimizer
                </MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Agents" Icon="@Icons.Material.Filled.Hub" Expanded="true">
                <MudNavLink Href="/agents" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.LibraryBooks">
                    Registry
                </MudNavLink>
                <MudNavLink Href="/workshop" Icon="@Icons.Material.Filled.SmartToy">
                    Workshop
                </MudNavLink>
                <MudNavLink Href="/workshop/instance/preview" Icon="@Icons.Material.Filled.Visibility">
                    Session view (preview)
                </MudNavLink>
            </MudNavGroup>

            <MudNavLink Href="/refinery" Icon="@Icons.Material.Filled.Science">
                Refinery
            </MudNavLink>

            <MudNavGroup Title="Routing" Icon="@Icons.Material.Filled.Route" Expanded="true">
                <MudNavLink Href="/clients" Icon="@Icons.Material.Filled.Groups">
                    Clients
                </MudNavLink>
                <MudNavLink Href="/models" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Memory">
                    Models
                </MudNavLink>
                <MudNavLink Href="/providers" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Cloud">
                    Providers
                </MudNavLink>
                <MudNavLink Href="/inference" Icon="@Icons.Material.Filled.ReceiptLong">
                    Inference
                </MudNavLink>
                <MudNavLink Href="/embeddings" Icon="@Icons.Material.Filled.ScatterPlot">
                    Embeddings
                </MudNavLink>
            </MudNavGroup>

            <MudDivider Class="my-2" />
            <MudNavLink Href="/usage"
                        Icon="@Icons.Material.Filled.BarChart">
                Usage
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            <CascadingValue Value="_isDarkMode" Name="ForgeDarkMode">
                @Body
            </CascadingValue>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
}
