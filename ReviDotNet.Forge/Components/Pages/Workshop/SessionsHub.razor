@using Revi
@using ReviDotNet.Forge.Services.Workshop
@using ReviDotNet.Forge.Services.Workshop.Models
@implements IDisposable
@inject IWorkshopStore Store
@inject IAgentManager Agents
@inject IDialogService DialogSvc
@inject NavigationManager Nav

@*
    Sessions list — every workshop session across all agents (filterable by agent). A session is one
    task run against an agent (Fixed) or an interactive conversation (Chat). Selecting one opens its
    dedicated viewer page; "New Session" composes one and opens it.
*@

<div class="d-flex align-center mb-3 gap-3" style="flex-wrap: wrap;">
    <MudText Typo="Typo.subtitle1">Sessions</MudText>
    <MudSelect T="string" @bind-Value="_agentFilter" Label="Agent" Dense="true" Margin="Margin.Dense"
               Variant="Variant.Outlined" Style="max-width: 240px;" Clearable="true">
        <MudSelectItem T="string" Value="@("")">All agents</MudSelectItem>
        @foreach (var name in AgentNames)
        {
            <MudSelectItem T="string" Value="@name">@name</MudSelectItem>
        }
    </MudSelect>
    <MudText Typo="Typo.caption" Color="Color.Secondary">@FilteredSessions.Count shown</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewSession">
        New Session
    </MudButton>
</div>

<MudPaper Outlined="true" Style="max-height: 74vh; overflow-y: auto;">
    @if (FilteredSessions.Count == 0)
    {
        <div class="pa-4">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                No sessions yet. Click <strong>New Session</strong> to run or chat with an agent.
            </MudText>
        </div>
    }
    else
    {
        <MudList T="string" Dense="true">
            @foreach (var s in FilteredSessions)
            {
                var session = s;
                <MudListItem T="string" OnClick="@(() => Open(session.Id))">
                    <div class="d-flex align-center gap-2" style="width:100%; min-width:0;">
                        <MudIcon Icon="@SessionIcon(session)" Color="@SessionColor(session)" Size="Size.Small" />
                        <div style="min-width:0; flex:1;">
                            <div class="d-flex align-center gap-1">
                                <MudText Typo="Typo.body2">@session.AgentName</MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Class="ma-0"
                                         Color="@(session.Mode == InteractionMode.Chat ? Color.Tertiary : Color.Default)">
                                    @(session.Mode == InteractionMode.Chat ? "chat" : "fixed")
                                </MudChip>
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                     Style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:block;">
                                @TaskPreview(session)
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @VersionLabel(session) · @FormatAge(session.CreatedAt)
                            </MudText>
                        </div>
                        <MudChip T="string" Size="Size.Small" Color="@SessionColor(session)" Class="ma-0 flex-none">
                            @SessionStatus(session)
                        </MudChip>
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Default" />
                    </div>
                </MudListItem>
            }
        </MudList>
    }
</MudPaper>

@code {
    private string _agentFilter = "";
    private IReadOnlyList<WorkshopSession> _sessions = Array.Empty<WorkshopSession>();

    private IReadOnlyList<WorkshopSession> FilteredSessions =>
        string.IsNullOrEmpty(_agentFilter)
            ? _sessions
            : _sessions.Where(s => string.Equals(s.AgentName, _agentFilter, StringComparison.Ordinal)).ToList();

    private IEnumerable<string> AgentNames => _sessions.Select(s => s.AgentName).Distinct().OrderBy(n => n);

    protected override void OnInitialized()
    {
        Store.Changed += OnStoreChanged;
        _sessions = Store.GetAllSessions();
    }

    private void OnStoreChanged() => InvokeAsync(() => { _sessions = Store.GetAllSessions(); StateHasChanged(); });

    private void Open(string id) => Nav.NavigateTo($"/workshop/session/{id}");

    private async Task OpenNewSession()
    {
        var parameters = new DialogParameters { ["AgentName"] = string.IsNullOrEmpty(_agentFilter) ? null : _agentFilter };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogSvc.ShowAsync<NewSessionDialog>("New Session", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not NewSessionSpec spec) return;

        var profile = Agents.Get(spec.AgentName);
        var session = new WorkshopSession
        {
            Id = Guid.NewGuid().ToString("N")[..8],
            AgentName = spec.AgentName,
            AgentVersion = profile?.Version,
            Mode = spec.Mode,
            Task = spec.Task,
            AdditionalInputs = spec.Mode == InteractionMode.Fixed
                ? spec.Inputs.ToDictionary(kv => kv.Key, kv => (object)kv.Value, StringComparer.OrdinalIgnoreCase)
                : null,
            RunCount = spec.Mode == InteractionMode.Chat ? 1 : Math.Max(1, spec.Runs),
            Attachments = spec.Attachments,
        };
        Store.AddSession(session);
        Nav.NavigateTo($"/workshop/session/{session.Id}");
    }

    // ── display helpers ─────────────────────────────────────────────────────

    private static string TaskPreview(WorkshopSession s)
    {
        if (s.Mode == InteractionMode.Chat)
            return s.Turns.Count == 0 ? (string.IsNullOrWhiteSpace(s.Task) ? "(empty chat)" : Trunc(s.Task, 80)) : Trunc(s.Turns[0].UserMessage, 80);
        return string.IsNullOrWhiteSpace(s.Task) ? "(no task)" : Trunc(s.Task, 80);
    }

    private static string Trunc(string t, int n) => t.Length > n ? t[..n] + "…" : t;
    private static string VersionLabel(WorkshopSession s) => s.AgentVersion.HasValue ? $"v{s.AgentVersion}" : "—";

    private static string FormatAge(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span.TotalSeconds < 60) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private static string SessionStatus(WorkshopSession s)
    {
        if (s.Mode == InteractionMode.Chat) return $"{s.Turns.Count} turn(s)";
        if (!s.IsComplete) return "pending";
        if (s.Stats is { } st) return st.Failed > 0 ? $"{st.Completed}/{st.TotalRuns} ✓" : $"✓ {st.Completed}/{st.TotalRuns}";
        return "—";
    }

    private static Color SessionColor(WorkshopSession s)
    {
        if (s.Mode == InteractionMode.Chat) return Color.Tertiary;
        if (!s.IsComplete) return Color.Info;
        if (s.Stats is { } st) return st.Failed > 0 ? (st.Completed == 0 ? Color.Error : Color.Warning) : Color.Success;
        return Color.Default;
    }

    private static string SessionIcon(WorkshopSession s)
    {
        if (s.Mode == InteractionMode.Chat) return Icons.Material.Filled.Chat;
        if (!s.IsComplete) return Icons.Material.Filled.HourglassEmpty;
        if (s.Stats is { } st) return st.Completed == st.TotalRuns && st.TotalRuns > 0
            ? Icons.Material.Filled.CheckCircle
            : (st.Completed == 0 ? Icons.Material.Filled.Error : Icons.Material.Filled.Warning);
        return Icons.Material.Filled.RadioButtonUnchecked;
    }

    public void Dispose() => Store.Changed -= OnStoreChanged;
}
