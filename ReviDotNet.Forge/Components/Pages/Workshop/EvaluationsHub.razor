@using Revi
@using ReviDotNet.Forge.Services.Workshop
@using ReviDotNet.Forge.Services.Workshop.Models
@implements IDisposable
@inject IWorkshopStore Store
@inject IDialogService DialogSvc
@inject WorkshopHandoff Handoff
@inject NavigationManager Nav

@*
    Evaluations list — every LLM evaluation across all agents (filterable by agent). Selecting one
    opens its dedicated viewer page; "New Evaluation" composes a request and opens the create flow.
*@

<div class="d-flex align-center mb-3 gap-3" style="flex-wrap: wrap;">
    <MudText Typo="Typo.subtitle1">Evaluations</MudText>
    <MudSelect T="string" @bind-Value="_agentFilter" Label="Agent" Dense="true" Margin="Margin.Dense"
               Variant="Variant.Outlined" Style="max-width: 240px;" Clearable="true">
        <MudSelectItem T="string" Value="@("")">All agents</MudSelectItem>
        @foreach (var name in AgentNames)
        {
            <MudSelectItem T="string" Value="@name">@name</MudSelectItem>
        }
    </MudSelect>
    <MudText Typo="Typo.caption" Color="Color.Secondary">@FilteredEvaluations.Count shown</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewEvaluation">
        New Evaluation
    </MudButton>
</div>

<MudPaper Outlined="true" Style="max-height: 74vh; overflow-y: auto;">
    @if (FilteredEvaluations.Count == 0)
    {
        <div class="pa-4">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                No evaluations yet. Click <strong>New Evaluation</strong> to run &amp; assess an agent.
            </MudText>
        </div>
    }
    else
    {
        <MudList T="string" Dense="true">
            @foreach (var ev in FilteredEvaluations)
            {
                var evaluation = ev;
                <MudListItem T="string" OnClick="@(() => Open(evaluation.Id))">
                    <div class="d-flex align-center gap-2" style="width:100%; min-width:0;">
                        <MudIcon Icon="@VerdictIcon(evaluation.Result.Verdict)" Color="@ScoreColor(evaluation.Result.Score)" Size="Size.Small" />
                        <div style="min-width:0; flex:1;">
                            <div class="d-flex align-center gap-1">
                                <MudText Typo="Typo.body2">@evaluation.AgentName</MudText>
                                @if (evaluation.AppliedAsVersion.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" Class="ma-0">applied</MudChip>
                                }
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                     Style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:block;">
                                @TaskPreview(evaluation.Task)
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @VersionLabel(evaluation.AgentVersion) · @evaluation.SessionIds.Count run(s) · @FormatAge(evaluation.CreatedAt)
                            </MudText>
                        </div>
                        <MudChip T="string" Size="Size.Small" Color="@ScoreColor(evaluation.Result.Score)" Class="ma-0 flex-none">
                            @($"{evaluation.Result.Score:0.0}")
                        </MudChip>
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Default" />
                    </div>
                </MudListItem>
            }
        </MudList>
    }
</MudPaper>

@code {
    private string _agentFilter = "";
    private IReadOnlyList<WorkshopEvaluation> _evaluations = Array.Empty<WorkshopEvaluation>();

    private IReadOnlyList<WorkshopEvaluation> FilteredEvaluations =>
        string.IsNullOrEmpty(_agentFilter)
            ? _evaluations
            : _evaluations.Where(e => string.Equals(e.AgentName, _agentFilter, StringComparison.Ordinal)).ToList();

    private IEnumerable<string> AgentNames => _evaluations.Select(e => e.AgentName).Distinct().OrderBy(n => n);

    protected override void OnInitialized()
    {
        Store.Changed += OnStoreChanged;
        _evaluations = Store.GetAllEvaluations();
    }

    private void OnStoreChanged() => InvokeAsync(() => { _evaluations = Store.GetAllEvaluations(); StateHasChanged(); });

    private void Open(string id) => Nav.NavigateTo($"/workshop/evaluation/{id}");

    private async Task OpenNewEvaluation()
    {
        var parameters = new DialogParameters { ["AgentName"] = string.IsNullOrEmpty(_agentFilter) ? null : _agentFilter };
        var dialog = await DialogSvc.ShowAsync<NewEvaluationDialog>("New Evaluation", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not NewEvaluationSpec spec) return;

        Handoff.PendingEvaluation = spec;
        Nav.NavigateTo("/workshop/evaluation/new");
    }

    private static string TaskPreview(string? task)
        => string.IsNullOrWhiteSpace(task) ? "(no task)" : (task!.Length > 80 ? task[..80] + "…" : task);

    private static string VersionLabel(int? version) => version.HasValue ? $"v{version}" : "—";

    private static string FormatAge(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span.TotalSeconds < 60) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private static Color ScoreColor(double score) => score >= 7.5 ? Color.Success : score >= 5.0 ? Color.Warning : Color.Error;

    private static string VerdictIcon(string verdict) => verdict?.ToLowerInvariant() switch
    {
        "pass" or "good" or "excellent" => Icons.Material.Filled.CheckCircle,
        "fail" or "poor" or "bad" => Icons.Material.Filled.Error,
        _ => Icons.Material.Filled.RateReview
    };

    public void Dispose() => Store.Changed -= OnStoreChanged;
}
