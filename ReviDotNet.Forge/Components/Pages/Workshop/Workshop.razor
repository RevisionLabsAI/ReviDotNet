@page "/workshop"
@using Revi
@using ReviDotNet.Forge.Services.Workshop
@using ReviDotNet.Forge.Services.Workshop.Models

<PageTitle>Agent Workshop — ReviDotNet Forge</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">Agent Workshop</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Run agents as <strong>sessions</strong> — a fixed task run or an interactive chat — then score them as
    <strong>evaluations</strong> with ranked recommendations and apply the suggested <code>.agent</code> revisions.
    Pick the agent when you create a session; version history lives in the Agents <strong>Registry</strong>.
</MudText>

<MudTabs Elevation="2" Rounded="true" Color="Color.Primary" @bind-ActivePanelIndex="_activeTab">
    <MudTabPanel Text="Sessions" Icon="@Icons.Material.Filled.PlayArrow">
        <div class="pa-4">
            <SessionsHub />
        </div>
    </MudTabPanel>
    <MudTabPanel Text="Evaluations" Icon="@Icons.Material.Filled.RateReview">
        <div class="pa-4">
            <EvaluationsHub />
        </div>
    </MudTabPanel>
</MudTabs>

@code {
    [SupplyParameterFromQuery] public int? Tab { get; set; }

    private int _activeTab;

    protected override void OnInitialized()
    {
        if (Tab is >= 0 and < 2) _activeTab = Tab.Value;
    }
}
