@using Revi
@using Newtonsoft.Json.Linq
@using ReviDotNet.Forge.Services.Workshop
@using ReviDotNet.Forge.Services.Workshop.Models
@implements IDisposable
@inject IWorkshopStore Store
@inject IAgentWorkshopService WorkshopSvc
@inject IAgentManager Agents
@inject IDialogService DialogSvc
@inject ISnackbar Snackbar
@inject RunningJobsService JobsSvc

@*
    Instances hub — master/detail list of persisted run instances for one agent.
    Replaces the old Run + Trace + History tabs: "New Instance" opens a composer,
    each instance persists its runs (durable trace in ReviLog), and selecting one
    shows aggregate stats + the full per-run event trace.
*@

<div class="d-flex align-center mb-3">
    <MudText Typo="Typo.subtitle1">Instances</MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">@_instances.Count for @AgentName</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenNewInstance"
               Disabled="@string.IsNullOrWhiteSpace(AgentName)">
        New Instance
    </MudButton>
</div>

<MudGrid Spacing="3">
    <!-- Master list -->
    <MudItem xs="12" md="4">
        <MudPaper Outlined="true" Style="max-height: 70vh; overflow-y: auto;">
            @if (_instances.Count == 0)
            {
                <div class="pa-4">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No instances yet. Click <strong>New Instance</strong> to run this agent on a task.
                    </MudText>
                </div>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @for (int i = 0; i < _instances.Count; i++)
                    {
                        var inst = _instances[i];
                        var number = _instances.Count - i; // newest gets the highest number
                        var selected = string.Equals(inst.Id, _selectedId, StringComparison.Ordinal);
                        <MudListItem T="string"
                                     OnClick="@(() => SelectInstanceAsync(inst.Id))"
                                     Style="@(selected ? "background-color: var(--mud-palette-action-default-hover);" : "")">
                            <div class="d-flex align-center gap-2" style="width:100%; min-width:0;">
                                <MudIcon Icon="@InstanceIcon(inst)" Color="@InstanceColor(inst)" Size="Size.Small" />
                                <div style="min-width:0; flex:1;">
                                    <MudText Typo="Typo.body2">Instance #@number</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                             Style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:block;">
                                        @TaskPreview(inst.Task)
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @VersionLabel(inst) · @inst.RunCount run(s) · @FormatAge(inst.CreatedAt)
                                    </MudText>
                                </div>
                                <MudChip T="string" Size="Size.Small" Color="@InstanceColor(inst)" Class="ma-0 flex-none">
                                    @InstanceStatus(inst)
                                </MudChip>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>

    <!-- Detail -->
    <MudItem xs="12" md="8">
        @if (_selected is null)
        {
            <MudPaper Class="pa-6" Outlined="true">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Select an instance to see its runs, or create a new one.
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudPaper Class="pa-3 mb-3" Outlined="true">
                <div class="d-flex align-center gap-2 mb-1">
                    <MudText Typo="Typo.subtitle2">@_selected.AgentName</MudText>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@VersionLabel(_selected)</MudChip>
                    <MudSpacer />
                    <MudButton Size="Size.Small"
                               Variant="Variant.Filled"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Analytics"
                               OnClick="@(() => OnEvaluateRequested.InvokeAsync(_selected))"
                               Disabled="@(!_selected.IsComplete || _selected.SessionIds.Count == 0)">
                        Evaluate these runs →
                    </MudButton>
                </div>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="white-space: pre-wrap;">@_selected.Task</MudText>
            </MudPaper>

            @if (_selected.Stats is { } stats)
            {
                <MudPaper Class="pa-3 mb-3" Outlined="true">
                    <MudGrid Spacing="2">
                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total runs</MudText>
                            <MudText Typo="Typo.h6">@stats.TotalRuns</MudText>
                        </MudItem>
                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Completed</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Success">@stats.Completed</MudText>
                        </MudItem>
                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Failed</MudText>
                            <MudText Typo="Typo.h6" Color="@(stats.Failed > 0 ? Color.Error : Color.Default)">@stats.Failed</MudText>
                        </MudItem>
                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Success rate</MudText>
                            <MudText Typo="Typo.h6">@($"{stats.SuccessRate * 100:0}%")</MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }

            @if (_loadingRuns)
            {
                <div class="d-flex align-center gap-2 pa-2">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <MudText Typo="Typo.caption">Loading runs…</MudText>
                </div>
            }

            <MudExpansionPanels MultiExpansion="true" Elevation="0">
            @foreach (var (sessionId, runState) in CurrentRuns.OrderBy(kv => kv.Value.RunIndex))
            {
                <MudExpansionPanel Class="mb-2">
                    <TitleContent>
                        <div class="d-flex align-center gap-2 flex-grow-1">
                            <MudIcon Icon="@RunStateIcon(runState)" Color="@RunStateColor(runState)" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle2">Run #@(runState.RunIndex + 1) — @sessionId[..Math.Min(8, sessionId.Length)]…</MudText>
                            <MudSpacer />
                            <MudChip T="string" Size="Size.Small" Color="@RunStateColor(runState)">@RunStateLabel(runState)</MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@(runState.Events.Count) events</MudChip>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <div class="pa-2">
                            @if (runState.FinalResult != null)
                            {
                                <MudPaper Class="pa-3 mb-2" Outlined="true">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Final output</MudText>
                                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: monospace;">@(runState.FinalResult.FinalOutput ?? "(empty)")</MudText>
                                </MudPaper>
                            }
                            @if (!string.IsNullOrEmpty(runState.ErrorMessage))
                            {
                                <MudAlert Severity="Severity.Error" Class="mb-2">@runState.ErrorMessage</MudAlert>
                            }
                            <AgentEventTrace Events="@runState.Events" />
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            }
            </MudExpansionPanels>
        }
    </MudItem>
</MudGrid>

@code {
    /// <summary>Agent currently selected in the workshop rail.</summary>
    [Parameter] public string AgentName { get; set; } = string.Empty;

    /// <summary>Raised when the user clicks "Evaluate these runs" — the shell switches tabs.</summary>
    [Parameter] public EventCallback<WorkshopInstance> OnEvaluateRequested { get; set; }

    private string? _lastAgentName;
    private string? _selectedId;
    private WorkshopInstance? _selected;
    private bool _loadingRuns;
    private string? _runningInstanceId;

    private IReadOnlyList<WorkshopInstance> _instances = Array.Empty<WorkshopInstance>();

    // Per-instance run buffers (sessionId → events/result). Live during a run and cached
    // after reload from ReviLog, so re-selecting an instance is instant.
    private readonly Dictionary<string, Dictionary<string, RunState>> _runsByInstance = new(StringComparer.Ordinal);

    private Dictionary<string, RunState> CurrentRuns =>
        _selectedId != null && _runsByInstance.TryGetValue(_selectedId, out var d) ? d : _empty;
    private static readonly Dictionary<string, RunState> _empty = new();

    private sealed class RunState
    {
        public required int RunIndex { get; init; }
        public required string SessionId { get; init; }
        public List<RlogEvent> Events { get; } = new();
        public AgentResult? FinalResult { get; set; }
        public string? ErrorMessage { get; set; }
        public bool IsDone => FinalResult != null || !string.IsNullOrEmpty(ErrorMessage);
    }

    protected override void OnInitialized() => Store.Changed += OnStoreChanged;

    protected override void OnParametersSet()
    {
        if (!string.Equals(_lastAgentName, AgentName, StringComparison.Ordinal))
        {
            _lastAgentName = AgentName;
            _selectedId = null;
            _selected = null;
        }
        _instances = Store.GetInstances(AgentName);
    }

    private void OnStoreChanged() => InvokeAsync(() =>
    {
        _instances = Store.GetInstances(AgentName);
        StateHasChanged();
    });

    private async Task SelectInstanceAsync(string id)
    {
        _selectedId = id;
        _selected = Store.GetInstance(id);
        if (_selected != null && !_runsByInstance.ContainsKey(id))
            await LoadRunsAsync(_selected);
        StateHasChanged();
    }

    private async Task OpenNewInstance()
    {
        var parameters = new DialogParameters { ["AgentName"] = AgentName };
        var dialog = await DialogSvc.ShowAsync<NewInstanceDialog>("New Instance", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not NewInstanceSpec spec) return;

        await RunInstanceAsync(spec);
    }

    private async Task RunInstanceAsync(NewInstanceSpec spec)
    {
        var profile = Agents.Get(spec.AgentName);
        var instance = new WorkshopInstance
        {
            Id = Guid.NewGuid().ToString("N")[..8],
            AgentName = spec.AgentName,
            AgentVersion = profile?.Version,
            Task = spec.Task,
            AdditionalInputs = spec.Inputs.ToDictionary(kv => kv.Key, kv => (object)kv.Value, StringComparer.OrdinalIgnoreCase),
            RunCount = spec.Runs
        };
        Store.AddInstance(instance);

        var runs = new Dictionary<string, RunState>(StringComparer.Ordinal);
        _runsByInstance[instance.Id] = runs;
        _selectedId = instance.Id;
        _selected = instance;
        _runningInstanceId = instance.Id;

        var cts = new CancellationTokenSource();
        string jobId = JobsSvc.Register(JobKind.AgentRun, $"Run {spec.AgentName} × {spec.Runs}", () => cts.Cancel());

        var request = new WorkshopRunRequest
        {
            AgentName = spec.AgentName,
            Task = spec.Task,
            AdditionalInputs = instance.AdditionalInputs,
            Runs = spec.Runs
        };

        try
        {
            await foreach (var update in WorkshopSvc.RunMultiAsync(request, cts.Token))
            {
                if (!runs.TryGetValue(update.SessionId, out var state))
                {
                    state = new RunState { RunIndex = update.RunIndex, SessionId = update.SessionId };
                    runs[update.SessionId] = state;
                    if (!instance.SessionIds.Contains(update.SessionId))
                        instance.SessionIds.Add(update.SessionId);
                }
                if (update.Event != null) state.Events.Add(update.Event);
                if (update.FinalResult != null) state.FinalResult = update.FinalResult;
                if (!string.IsNullOrEmpty(update.ErrorMessage)) state.ErrorMessage = update.ErrorMessage;

                instance.Stats = ComputeStats(runs.Values);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* user cancelled */ }
        catch (Exception ex)
        {
            Snackbar.Add($"Run failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            instance.Stats = ComputeStats(runs.Values);
            instance.IsComplete = true;
            _runningInstanceId = null;
            JobsSvc.Complete(jobId);
            cts.Dispose();
            Store.NotifyChanged();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadRunsAsync(WorkshopInstance instance)
    {
        _loadingRuns = true;
        StateHasChanged();
        var runs = new Dictionary<string, RunState>(StringComparer.Ordinal);
        try
        {
            for (int i = 0; i < instance.SessionIds.Count; i++)
            {
                var sid = instance.SessionIds[i];
                var events = await WorkshopSvc.GetSessionEventsAsync(sid, CancellationToken.None);
                var state = new RunState { RunIndex = i, SessionId = sid };
                state.Events.AddRange(events);
                state.FinalResult = DeriveResult(events);
                runs[sid] = state;
            }
            _runsByInstance[instance.Id] = runs;
            instance.Stats ??= ComputeStats(runs.Values);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load runs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingRuns = false;
            StateHasChanged();
        }
    }

    // ── stats + result reconstruction ───────────────────────────────────────

    private static AggregateStats ComputeStats(IEnumerable<RunState> states)
    {
        var list = states.ToList();
        int total = list.Count;
        int completed = list.Count(r => r.FinalResult?.ExitReason == AgentExitReason.Completed);
        int failed = list.Count(r => r.IsDone && r.FinalResult?.ExitReason != AgentExitReason.Completed);
        var done = list.Where(r => r.FinalResult != null).ToList();
        double avgSteps = done.Count > 0 ? done.Average(r => r.FinalResult!.TotalSteps) : 0;
        double avgDur = done.Where(r => r.Events.Count > 0)
            .Select(r => (r.Events.Max(e => e.Timestamp) - r.Events.Min(e => e.Timestamp)).TotalSeconds)
            .DefaultIfEmpty(0).Average();
        return new AggregateStats
        {
            TotalRuns = total,
            Completed = completed,
            Failed = failed,
            SuccessRate = total == 0 ? 0 : (double)completed / total,
            AverageDurationSeconds = avgDur,
            AverageSteps = avgSteps
        };
    }

    // Rebuild a minimal AgentResult from a reloaded session's End event.
    private static AgentResult? DeriveResult(IReadOnlyList<RlogEvent> events)
    {
        var end = events.FirstOrDefault(e => e.Identifier == AgentReviLogger.Step.End);
        if (end == null) return null;

        var exit = AgentExitReason.Completed;
        int steps = 0;
        if (!string.IsNullOrEmpty(end.Object2))
        {
            try
            {
                var meta = JObject.Parse(end.Object2);
                if (Enum.TryParse<AgentExitReason>((string?)meta["exitReason"], ignoreCase: true, out var parsed))
                    exit = parsed;
                steps = (int?)meta["totalSteps"] ?? 0;
            }
            catch { /* ignore malformed meta */ }
        }
        return new AgentResult { FinalOutput = end.Object1, ExitReason = exit, TotalSteps = steps };
    }

    // ── display helpers ─────────────────────────────────────────────────────

    private static string TaskPreview(string task)
        => string.IsNullOrWhiteSpace(task) ? "(no task)" : (task.Length > 80 ? task[..80] + "…" : task);

    private static string VersionLabel(WorkshopInstance i) => i.AgentVersion.HasValue ? $"v{i.AgentVersion}" : "—";

    private static string FormatAge(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span.TotalSeconds < 60) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private bool IsRunning(WorkshopInstance i) => string.Equals(i.Id, _runningInstanceId, StringComparison.Ordinal);

    private string InstanceStatus(WorkshopInstance i)
    {
        if (IsRunning(i)) return "running";
        if (i.Stats is { } s) return s.Failed > 0 ? $"{s.Completed}/{s.TotalRuns} ✓" : $"✓ {s.Completed}/{s.TotalRuns}";
        return "—";
    }

    private Color InstanceColor(WorkshopInstance i)
    {
        if (IsRunning(i)) return Color.Info;
        if (i.Stats is { } s) return s.Failed > 0 ? (s.Completed == 0 ? Color.Error : Color.Warning) : Color.Success;
        return Color.Default;
    }

    private string InstanceIcon(WorkshopInstance i)
    {
        if (IsRunning(i)) return Icons.Material.Filled.HourglassEmpty;
        if (i.Stats is { } s) return s.Completed == s.TotalRuns && s.TotalRuns > 0
            ? Icons.Material.Filled.CheckCircle
            : (s.Completed == 0 ? Icons.Material.Filled.Error : Icons.Material.Filled.Warning);
        return Icons.Material.Filled.RadioButtonUnchecked;
    }

    private static string RunStateIcon(RunState s) =>
        s.FinalResult?.ExitReason == AgentExitReason.Completed ? Icons.Material.Filled.CheckCircle :
        !string.IsNullOrEmpty(s.ErrorMessage) || (s.FinalResult != null && s.FinalResult.ExitReason != AgentExitReason.Completed) ? Icons.Material.Filled.Error :
        Icons.Material.Filled.HourglassEmpty;

    private static Color RunStateColor(RunState s) =>
        s.FinalResult?.ExitReason == AgentExitReason.Completed ? Color.Success :
        !string.IsNullOrEmpty(s.ErrorMessage) || (s.FinalResult != null && s.FinalResult.ExitReason != AgentExitReason.Completed) ? Color.Error :
        Color.Info;

    private static string RunStateLabel(RunState s) =>
        s.FinalResult?.ExitReason.ToString() ?? (string.IsNullOrEmpty(s.ErrorMessage) ? "running" : "error");

    public void Dispose() => Store.Changed -= OnStoreChanged;
}
