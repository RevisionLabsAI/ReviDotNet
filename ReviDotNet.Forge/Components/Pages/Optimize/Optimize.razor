@page "/optimize"
@inject PromptRegistryService Registry
@inject OptimizerService Optimizer
@inject TestRunnerService Runner
@inject ISnackbar Snackbar
@inject IModelManager Models
@inject WorkbenchStateService Workbench
@inject RunningJobsService JobsSvc

<PageTitle>Optimizer — ReviDotNet Optimizer</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Optimizer</MudText>

<MudGrid Spacing="3">

    <!-- Left rail: prompt browser -->
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-3" Elevation="2" Style="position: sticky; top: 80px;">
            <div class="d-flex align-center mb-2">
                <MudText Typo="Typo.subtitle2">Prompts</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               Size="Size.Small"
                               Title="New prompt"
                               OnClick="@GoToNewPrompt" />
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                               Size="Size.Small"
                               Title="Fork current as new version"
                               Disabled="@string.IsNullOrWhiteSpace(_selectedPromptName)"
                               OnClick="@ForkCurrentPrompt" />
            </div>
            <MudTextField @bind-Value="_promptSearch"
                          Placeholder="Search..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-2" />
            <MudList T="string" Dense="true" Style="max-height: 65vh; overflow-y: auto;">
                @foreach (var p in FilteredPrompts)
                {
                    var name = p.Name ?? string.Empty;
                    var selected = string.Equals(name, _selectedPromptName, StringComparison.Ordinal);
                    <MudListItem T="string"
                                 OnClick="@(() => SelectPrompt(name))"
                                 Style="@(selected ? "background-color: var(--mud-palette-action-default-hover);" : "")">
                        <div class="d-flex align-center gap-2">
                            @if (selected)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.RadioButtonChecked"
                                         Color="Color.Primary"
                                         Size="Size.Small" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.RadioButtonUnchecked"
                                         Size="Size.Small" />
                            }
                            <div>
                                <MudText Typo="Typo.body2">@name</MudText>
                                @if (p.Version.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">v@(p.Version)</MudText>
                                }
                            </div>
                        </div>
                    </MudListItem>
                }
                @if (!FilteredPrompts.Any())
                {
                    <MudListItem T="string" Disabled="true">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">No prompts match.</MudText>
                    </MudListItem>
                }
            </MudList>
        </MudPaper>
    </MudItem>

    <!-- Detail: existing 3-tab workflow -->
    <MudItem xs="12" md="9">

<MudTabs Elevation="2" Rounded="true" Color="Color.Primary" @bind-ActivePanelIndex="_activeTab">

    <!-- Tab 1: Analysis -->
    <MudTabPanel Text="Analysis" Icon="@Icons.Material.Filled.Analytics">
        <div class="pa-4">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_selectedPromptName"
                               Label="Prompt"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               Class="mb-3">
                        @foreach (var p in Registry.GetAll().OrderBy(p => p.Name))
                        {
                            <MudSelectItem Value="@(p.Name ?? string.Empty)">@p.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="string"
                               SelectedValues="_selectedModelNames"
                               SelectedValuesChanged="@OnModelsChanged"
                               MultiSelection="true"
                               Label="Models (one or more)"
                               HelperText="Runs analysis once per selected model — quality is broken down per model."
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               Class="mb-3">
                        @foreach (var m in Models.GetAll())
                        {
                            <MudSelectItem T="string" Value="@(m.Name ?? string.Empty)">@m.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudNumericField @bind-Value="_analysisRuns"
                                     Label="Test Runs to Analyze"
                                     Min="1" Max="10"
                                     Variant="Variant.Outlined"
                                     FullWidth="true"
                                     Class="mb-3" />

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Inputs</MudText>
                    @for (int i = 0; i < _analysisInputs.Count; i++)
                    {
                        int idx = i;
                        <div class="d-flex gap-2 mb-2">
                            <MudTextField @bind-Value="_analysisInputs[idx].Label"
                                          Label="Key"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Style="max-width: 130px;" />
                            <MudTextField @bind-Value="_analysisInputs[idx].Value"
                                          Label="Value"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          FullWidth="true" />
                        </div>
                    }
                    <MudButton Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@(() => _analysisInputs.Add(new AnalysisInputPair()))"
                               Class="mb-4">
                        Add Input
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Analytics"
                               OnClick="@RunAnalysis"
                               Disabled="@(_analyzing || string.IsNullOrWhiteSpace(_selectedPromptName))">
                        @(_analyzing ? "Analyzing..." : "Analyze Results")
                    </MudButton>

                    @if (_analyzing)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-3" />
                    }
                </MudItem>

                <MudItem xs="12" md="8">
                    @if (_analyses.Count > 0)
                    {
                        <!-- Aggregate Stats -->
                        <MudGrid Spacing="2" Class="mb-4">
                            <MudItem xs="6" sm="4">
                                <MudPaper Class="pa-3 text-center" Elevation="1">
                                    <MudText Typo="Typo.h6">@($"{_analyses.Count(a => a.FulfilledRequest) * 100.0 / _analyses.Count:F0}%")</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Fulfilled</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="6" sm="4">
                                <MudPaper Class="pa-3 text-center" Elevation="1">
                                    <MudText Typo="Typo.h6">@($"{_analyses.Average(a => a.QualityScore):F1}/10")</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Avg Quality</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudPaper Class="pa-3 text-center" Elevation="1">
                                    <MudText Typo="Typo.h6">@_analyses.Count</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Runs Analyzed</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                        @if (_analysesByModel.Count > 1)
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Per-model breakdown</MudText>
                            <MudGrid Spacing="2" Class="mb-4">
                                @foreach (var (model, list) in _analysesByModel.OrderBy(kv => kv.Key))
                                {
                                    <MudItem xs="6" sm="4" md="3">
                                        <MudPaper Class="pa-3" Outlined="true">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@model</MudText>
                                            <MudText Typo="Typo.body2">@($"{list.Average(a => a.QualityScore):F1}/10")</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @($"{list.Count(a => a.FulfilledRequest) * 100.0 / list.Count:F0}% fulfilled · {list.Count} run(s)")
                                            </MudText>
                                        </MudPaper>
                                    </MudItem>
                                }
                            </MudGrid>
                        }

                        <MudExpansionPanels Class="mb-3">
                            @for (int i = 0; i < _analyses.Count; i++)
                            {
                                var analysis = _analyses[i];
                                int num = i + 1;
                                <MudExpansionPanel Text="@($"Run {num} — Quality {analysis.QualityScore}/10 — {(analysis.FulfilledRequest ? "✓ Fulfilled" : "✗ Not Fulfilled")}")">
                                    <MudGrid Spacing="2">
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Analysis</MudText>
                                            <MudText Typo="Typo.body2">@analysis.Analysis</MudText>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Improvements</MudText>
                                            <MudText Typo="Typo.body2">@analysis.Improvements</MudText>
                                        </MudItem>
                                    </MudGrid>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Lightbulb"
                                   OnClick="@GoToSuggestions">
                            Generate Suggestions
                        </MudButton>
                    }
                    else if (!_analyzing)
                    {
                        <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="1" Style="min-height: 250px; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large" Style="opacity:0.3;" Class="mb-2" />
                            <MudText Style="opacity:0.5;">Run analysis to see results.</MudText>
                        </MudPaper>
                    }
                </MudItem>
            </MudGrid>
        </div>
    </MudTabPanel>

    <!-- Tab 2: Suggestions -->
    <MudTabPanel Text="Suggestions" Icon="@Icons.Material.Filled.Lightbulb">
        <div class="pa-4">
            @if (_suggestions.Count == 0 && !_generatingSuggestions)
            {
                <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="1" Style="min-height: 250px; justify-content: center;">
                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Size="Size.Large" Style="opacity:0.3;" Class="mb-2" />
                    <MudText Style="opacity:0.5;">Run analysis first, then click "Generate Suggestions".</MudText>
                </MudPaper>
            }
            else if (_generatingSuggestions)
            {
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Class="mt-2">Aggregating suggestions...</MudText>
            }
            else
            {
                <div class="d-flex align-center justify-space-between mb-4">
                    <MudText Typo="Typo.subtitle1">@_suggestions.Count Suggestions</MudText>
                    <div class="d-flex gap-2">
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@SelectAll">Select All</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@SelectNone">Deselect All</MudButton>
                    </div>
                </div>

                @foreach (var s in _suggestions)
                {
                    <MudCard Class="mb-3" Elevation="1">
                        <MudCardContent Class="d-flex gap-3">
                            <MudCheckBox @bind-Value="s.Selected" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.subtitle2">@s.Description</MudText>
                                <div class="d-flex gap-2 mt-1">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@s.AffectedSection</MudChip>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@s.ExpectedImpact</MudText>
                                </div>
                            </div>
                        </MudCardContent>
                    </MudCard>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Build"
                           OnClick="@GoToApply"
                           Disabled="@(!_suggestions.Any(s => s.Selected))">
                    Apply Selected Suggestions
                </MudButton>
            }
        </div>
    </MudTabPanel>

    <!-- Tab 3: Apply -->
    <MudTabPanel Text="Apply &amp; Iterate" Icon="@Icons.Material.Filled.Build">
        <div class="pa-4">
            @if (string.IsNullOrWhiteSpace(_revisedContent) && !_revising)
            {
                <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="1" Style="min-height: 250px; justify-content: center;">
                    <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Large" Style="opacity:0.3;" Class="mb-2" />
                    <MudText Style="opacity:0.5;">Select suggestions and click "Apply" to generate a revised prompt.</MudText>
                </MudPaper>
            }
            else
            {
                @if (_originalPrompt is not null)
                {
                    <DiffViewer Left="@PromptRegistryService.SerializePrompt(_originalPrompt)"
                                Right="@(_revisedContent + (_revising ? "▌" : string.Empty))"
                                LeftLabel="Original"
                                RightLabel="Revised"
                                LeftSubLabel="@($"v{_originalPrompt.Version}")"
                                RightSubLabel="@(_revising ? "streaming…" : "ready")" />
                }

                @if (_qualityDelta is not null)
                {
                    <MudPaper Class="pa-3 mt-4" Outlined="true">
                        <div class="d-flex align-center gap-3">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="@(_qualityDelta.Delta >= 0 ? Color.Success : Color.Error)" />
                            <div>
                                <MudText Typo="Typo.subtitle2">Quality delta</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @($"Baseline {_qualityDelta.Before:F1}/10 → New {_qualityDelta.After:F1}/10 ({(_qualityDelta.Delta >= 0 ? "+" : "")}{_qualityDelta.Delta:F1})")
                                </MudText>
                            </div>
                        </div>
                    </MudPaper>
                }
                else if (_postSaveAnalyzing)
                {
                    <MudPaper Class="pa-3 mt-4" Outlined="true">
                        <div class="d-flex align-center gap-2">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            <MudText Typo="Typo.caption">Measuring quality of new version…</MudText>
                        </div>
                    </MudPaper>
                }

                @if (!_revising && !string.IsNullOrWhiteSpace(_revisedContent))
                {
                    <div class="d-flex gap-3 mt-4">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="@AcceptRevision">
                            Accept &amp; Save
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="@TestRevised">
                            Test Revised Prompt
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="@GoToApply">
                            Revise Again
                        </MudButton>
                    </div>
                }
            }
        </div>
    </MudTabPanel>

</MudTabs>

    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery] public string? Prompt { get; set; }

    // Persisted snapshot — survives navigation across the session via WorkbenchStateService.
    public sealed class OptimizeWorkbench
    {
        public int ActiveTab { get; set; }
        public HashSet<string> ModelNames { get; set; } = new();
        public int AnalysisRuns { get; set; } = 3;
        public List<AnalysisInputPair> Inputs { get; set; } = new();
        public List<TaggedAnalysis> Analyses { get; set; } = new();
        public List<PromptSuggestion> Suggestions { get; set; } = new();
        public string RevisedContent { get; set; } = string.Empty;
        public QualityDelta? Delta { get; set; }
    }
    public sealed class AnalysisInputPair { public string Label { get; set; } = ""; public string Value { get; set; } = ""; }
    public sealed class TaggedAnalysis { public string Model { get; set; } = ""; public AnalysisResult Result { get; set; } = new(); }
    public sealed class QualityDelta { public double Before { get; set; } public double After { get; set; } public double Delta => After - Before; }

    private const string PageKey = "optimize";

    private int _activeTab;
    private string _selectedPromptName = string.Empty;
    private HashSet<string> _selectedModelNames = new();
    private string _promptSearch = string.Empty;
    private int _analysisRuns = 3;
    private List<AnalysisInputPair> _analysisInputs = [new AnalysisInputPair { Label = "Task" }];
    private bool _analyzing;
    private List<AnalysisResult> _analyses = new();
    private Dictionary<string, List<AnalysisResult>> _analysesByModel = new();
    private bool _generatingSuggestions;
    private List<PromptSuggestion> _suggestions = new();
    private bool _revising;
    private string _revisedContent = string.Empty;
    private Prompt? _originalPrompt;
    private QualityDelta? _qualityDelta;
    private bool _postSaveAnalyzing;
    private CancellationTokenSource? _cts;

    private IEnumerable<Prompt> FilteredPrompts => Registry.GetAll()
        .Where(p => string.IsNullOrWhiteSpace(_promptSearch) ||
                    (p.Name?.Contains(_promptSearch, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(p => p.Name);

    private void OnModelsChanged(IEnumerable<string> values)
    {
        _selectedModelNames = new HashSet<string>(values ?? Enumerable.Empty<string>(), StringComparer.OrdinalIgnoreCase);
        PersistState();
    }

    private void SelectPrompt(string name)
    {
        if (string.Equals(name, _selectedPromptName, StringComparison.Ordinal)) return;
        _selectedPromptName = name;
        RestoreOrResetState();
        StateHasChanged();
    }

    private void GoToNewPrompt() => Nav.NavigateTo("/generate");

    private void ForkCurrentPrompt()
    {
        if (string.IsNullOrWhiteSpace(_selectedPromptName)) return;
        Nav.NavigateTo($"/generate?fork={Uri.EscapeDataString(_selectedPromptName)}");
    }

    protected override void OnInitialized()
    {
        var models = Models.GetAll();
        // Default to first available model if user hasn't selected any yet.
        if (_selectedModelNames.Count == 0 && models.Count > 0)
            _selectedModelNames = new HashSet<string>(new[] { models[0].Name ?? string.Empty }, StringComparer.OrdinalIgnoreCase);

        if (!string.IsNullOrWhiteSpace(Prompt))
            _selectedPromptName = Prompt;
        else
            _selectedPromptName = Registry.GetAll().FirstOrDefault()?.Name ?? string.Empty;

        RestoreOrResetState();
    }

    private void RestoreOrResetState()
    {
        var wb = Workbench.Get<OptimizeWorkbench>(PageKey, _selectedPromptName);
        if (wb is not null)
        {
            _activeTab = wb.ActiveTab;
            if (wb.ModelNames.Count > 0) _selectedModelNames = new HashSet<string>(wb.ModelNames, StringComparer.OrdinalIgnoreCase);
            _analysisRuns = wb.AnalysisRuns;
            _analysisInputs = wb.Inputs.Count > 0 ? wb.Inputs : new() { new AnalysisInputPair { Label = "Task" } };
            _analyses = wb.Analyses.Select(t => t.Result).ToList();
            _analysesByModel = wb.Analyses.GroupBy(t => t.Model).ToDictionary(g => g.Key, g => g.Select(x => x.Result).ToList());
            _suggestions = wb.Suggestions;
            _revisedContent = wb.RevisedContent;
            _qualityDelta = wb.Delta;
            _originalPrompt = Registry.GetByName(_selectedPromptName);
        }
        else
        {
            _activeTab = 0;
            _analyses.Clear();
            _analysesByModel.Clear();
            _suggestions.Clear();
            _revisedContent = string.Empty;
            _originalPrompt = null;
            _qualityDelta = null;
        }
    }

    private void PersistState()
    {
        if (string.IsNullOrWhiteSpace(_selectedPromptName)) return;
        var tagged = new List<TaggedAnalysis>();
        foreach (var (model, list) in _analysesByModel)
            foreach (var a in list) tagged.Add(new TaggedAnalysis { Model = model, Result = a });

        Workbench.Set(PageKey, _selectedPromptName, new OptimizeWorkbench
        {
            ActiveTab = _activeTab,
            ModelNames = new HashSet<string>(_selectedModelNames, StringComparer.OrdinalIgnoreCase),
            AnalysisRuns = _analysisRuns,
            Inputs = _analysisInputs,
            Analyses = tagged,
            Suggestions = _suggestions,
            RevisedContent = _revisedContent,
            Delta = _qualityDelta
        });
    }

    private async Task RunAnalysis()
    {
        if (string.IsNullOrWhiteSpace(_selectedPromptName) || _selectedModelNames.Count == 0)
        {
            Snackbar.Add("Pick a prompt and at least one model first.", Severity.Warning);
            return;
        }

        _analyzing = true;
        _analyses.Clear();
        _analysesByModel.Clear();
        _suggestions.Clear();
        _revisedContent = string.Empty;
        _qualityDelta = null;

        var inputs = _analysisInputs
            .Where(i => !string.IsNullOrWhiteSpace(i.Label))
            .Select(i => new Input(i.Label, i.Value))
            .ToList();

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        string jobId = JobsSvc.Register(JobKind.Analyze, $"Analyze {_selectedPromptName} × {_selectedModelNames.Count} model(s)", () => _cts.Cancel());

        try
        {
            var channel = Runner.RunTests(
                _selectedPromptName,
                _selectedModelNames.ToList(),
                inputs,
                _analysisRuns,
                runAnalysis: true,
                _cts.Token);

            await foreach (var result in channel.Reader.ReadAllAsync(_cts.Token))
            {
                if (result.Analysis is not null)
                {
                    _analyses.Add(result.Analysis);
                    if (!_analysesByModel.TryGetValue(result.ModelName, out var list))
                        _analysesByModel[result.ModelName] = list = new();
                    list.Add(result.Analysis);
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Snackbar.Add($"Analysis failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _analyzing = false;
            JobsSvc.Complete(jobId);
            PersistState();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task GoToSuggestions()
    {
        _activeTab = 1;

        if (_analyses.Count == 0) return;

        _originalPrompt = Registry.GetByName(_selectedPromptName);
        if (_originalPrompt is null) return;

        _generatingSuggestions = true;
        StateHasChanged();

        string jobId = JobsSvc.Register(JobKind.Analyze, $"Suggest improvements for {_selectedPromptName}", () => { });
        try
        {
            _suggestions = await Optimizer.GenerateSuggestionsAsync(_originalPrompt, _analyses);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Suggestion generation failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _generatingSuggestions = false;
            JobsSvc.Complete(jobId);
            PersistState();
            StateHasChanged();
        }
    }

    private async Task GoToApply()
    {
        _activeTab = 2;
        _revisedContent = string.Empty;
        _revising = true;
        StateHasChanged();

        if (_originalPrompt is null) return;

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        string jobId = JobsSvc.Register(JobKind.Revise, $"Revise {_selectedPromptName}", () => _cts.Cancel());

        try
        {
            await foreach (var token in Optimizer.ReviseStreamAsync(
                _originalPrompt, _suggestions, _cts.Token))
            {
                _revisedContent += token;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Snackbar.Add($"Revision failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _revising = false;
            JobsSvc.Complete(jobId);
            PersistState();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AcceptRevision()
    {
        if (string.IsNullOrWhiteSpace(_revisedContent) || string.IsNullOrWhiteSpace(_selectedPromptName)) return;

        // Capture baseline quality (average over current analyses) before overwriting.
        double? before = _analyses.Count > 0 ? _analyses.Average(a => (double)a.QualityScore) : null;

        try
        {
            if (_originalPrompt is not null && _originalPrompt.Version.HasValue)
                _revisedContent = _revisedContent.Replace(
                    $"version = {_originalPrompt.Version}",
                    $"version = {_originalPrompt.Version + 1}");

            Registry.SaveNew(_selectedPromptName, _revisedContent);
            Snackbar.Add("Revised prompt saved. Measuring quality of new version…", Severity.Success);

            // Re-analyze with the same model selection and inputs to compute the delta.
            if (before is not null && _selectedModelNames.Count > 0)
            {
                _ = MeasureQualityDeltaAsync(before.Value);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task MeasureQualityDeltaAsync(double baseline)
    {
        _postSaveAnalyzing = true;
        await InvokeAsync(StateHasChanged);

        var ctsLocal = new CancellationTokenSource();
        string jobId = JobsSvc.Register(JobKind.Analyze, $"Re-analyze {_selectedPromptName} for quality delta", () => ctsLocal.Cancel());

        try
        {
            var inputs = _analysisInputs
                .Where(i => !string.IsNullOrWhiteSpace(i.Label))
                .Select(i => new Input(i.Label, i.Value))
                .ToList();

            // Use 2 quick runs per model — enough to estimate quality without burning budget.
            var channel = Runner.RunTests(
                _selectedPromptName,
                _selectedModelNames.ToList(),
                inputs,
                runsPerModel: 2,
                runAnalysis: true,
                ctsLocal.Token);

            var newScores = new List<int>();
            await foreach (var result in channel.Reader.ReadAllAsync(ctsLocal.Token))
            {
                if (result.Analysis is not null)
                    newScores.Add(result.Analysis.QualityScore);
            }

            if (newScores.Count > 0)
            {
                _qualityDelta = new QualityDelta
                {
                    Before = baseline,
                    After = newScores.Average()
                };
                PersistState();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Quality re-measurement failed: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _postSaveAnalyzing = false;
            JobsSvc.Complete(jobId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void TestRevised() =>
        Nav.NavigateTo($"/test?prompt={Uri.EscapeDataString(_selectedPromptName)}");

    private void SelectAll() { foreach (var s in _suggestions) s.Selected = true; }
    private void SelectNone() { foreach (var s in _suggestions) s.Selected = false; }
}

