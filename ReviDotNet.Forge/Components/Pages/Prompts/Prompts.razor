@page "/prompts"
@inject PromptRegistryService Registry
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject TestRunnerService Runner
@inject RunningJobsService JobsSvc
@inject IModelManager Models

<PageTitle>Prompt Registry — ReviDotNet Forge</PageTitle>

<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4">Prompt Registry</MudText>
    <MudSpacer />
    <MudTextField @bind-Value="_search"
                  Placeholder="Search prompts..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable="true"
                  Style="max-width: 300px;"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense" />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/prompts/new"
               Class="ml-3">
        Create New
    </MudButton>
</div>

@if (_selectedPrompts.Count > 0)
{
    <MudPaper Class="pa-2 mb-2 d-flex align-center gap-2" Outlined="true">
        <MudText Typo="Typo.body2">@_selectedPrompts.Count selected</MudText>
        <MudSpacer />
        <MudSelect T="string"
                   @bind-Value="_batchModelName"
                   Label="Model for batch"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Style="max-width: 240px;">
            @foreach (var m in Models.GetAll())
            {
                <MudSelectItem Value="@(m.Name ?? string.Empty)">@m.Name</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Analytics"
                   Disabled="@(_batchRunning || string.IsNullOrWhiteSpace(_batchModelName))"
                   OnClick="@RunBatchAnalysis">
            @(_batchRunning ? $"Analyzing… ({_batchProgress}/{_batchTotal})" : "Batch analyze")
        </MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.Clear"
                       Size="Size.Small"
                       Title="Clear selection"
                       OnClick="@(() => { _selectedPrompts.Clear(); StateHasChanged(); })" />
    </MudPaper>
}

@if (_batchResults.Count > 0)
{
    <MudPaper Class="pa-3 mb-3" Outlined="true">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Last batch results</MudText>
        <MudTable Items="@_batchResults" Dense="true">
            <HeaderContent>
                <MudTh>Prompt</MudTh>
                <MudTh>Avg quality</MudTh>
                <MudTh>Fulfilled</MudTh>
                <MudTh>Runs</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.PromptName</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.AvgQuality >= 8 ? Color.Success : context.AvgQuality >= 5 ? Color.Warning : Color.Error)">
                        @($"{context.AvgQuality:F1}/10")
                    </MudChip>
                </MudTd>
                <MudTd>@($"{context.FulfilledPercent:F0}%")</MudTd>
                <MudTd>@context.RunCount</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

<MudDataGrid Items="@FilteredPrompts"
             T="Prompt"
             MultiSelection="true"
             @bind-SelectedItems="_selectedPrompts"
             RowClick="@OnRowClick"
             Dense="true"
             Hover="true"
             Striped="true"
             Elevation="2">
    <Columns>
        <PropertyColumn Property="p => p.Name" Title="Name" />
        <PropertyColumn Property="p => p.Version" Title="Ver" />
        <TemplateColumn Title="Schema">
            <CellTemplate>
                @{
                    var schemaStr = PromptRegistryService.ToGuidanceSchemaString(context.Item.GuidanceSchema);
                }
                @if (schemaStr is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@schemaStr</MudChip>
                }
                else if (context.Item.RequestJson == true)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">JSON</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small">None</MudChip>
                }
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Examples">
            <CellTemplate>
                <MudText Typo="Typo.body2">@(context.Item.Examples?.Count ?? 0)</MudText>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="" CellStyle="text-align: right; width: 40px;" Sortable="false" Filterable="false">
            <CellTemplate>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Default" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    public sealed class BatchResult
    {
        public string PromptName { get; set; } = string.Empty;
        public double AvgQuality { get; set; }
        public double FulfilledPercent { get; set; }
        public int RunCount { get; set; }
    }

    private string _search = string.Empty;
    private HashSet<Prompt> _selectedPrompts = new();
    private string _batchModelName = string.Empty;
    private bool _batchRunning;
    private int _batchProgress;
    private int _batchTotal;
    private List<BatchResult> _batchResults = new();

    private IEnumerable<Prompt> FilteredPrompts => Registry.GetAll()
        .Where(p => string.IsNullOrWhiteSpace(_search) ||
                    (p.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(p => p.Name);

    protected override void OnInitialized()
    {
        var first = Models.GetAll().FirstOrDefault();
        _batchModelName = first?.Name ?? string.Empty;
    }

    private void OnRowClick(DataGridRowClickEventArgs<Prompt> args)
    {
        var name = args.Item?.Name;
        if (string.IsNullOrWhiteSpace(name)) return;
        Nav.NavigateTo($"/prompts/edit?name={Uri.EscapeDataString(name)}");
    }

    private async Task RunBatchAnalysis()
    {
        if (_selectedPrompts.Count == 0 || string.IsNullOrWhiteSpace(_batchModelName)) return;

        _batchRunning = true;
        _batchResults.Clear();
        _batchProgress = 0;
        _batchTotal = _selectedPrompts.Count;
        StateHasChanged();

        var cts = new CancellationTokenSource();
        string jobId = JobsSvc.Register(JobKind.Analyze, $"Batch analyze {_batchTotal} prompts on {_batchModelName}", () => cts.Cancel());

        try
        {
            foreach (var prompt in _selectedPrompts.ToList())
            {
                if (cts.Token.IsCancellationRequested) break;

                var name = prompt.Name ?? string.Empty;
                var scores = new List<int>();
                int fulfilled = 0;

                try
                {
                    var channel = Runner.RunTests(
                        name,
                        new[] { _batchModelName },
                        new List<Input> { new Input("Task", "") },
                        runsPerModel: 2,
                        runAnalysis: true,
                        cts.Token);

                    await foreach (var r in channel.Reader.ReadAllAsync(cts.Token))
                    {
                        if (r.Analysis is not null)
                        {
                            scores.Add(r.Analysis.QualityScore);
                            if (r.Analysis.FulfilledRequest) fulfilled++;
                        }
                    }
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"{name}: {ex.Message}", Severity.Warning);
                }

                _batchResults.Add(new BatchResult
                {
                    PromptName = name,
                    AvgQuality = scores.Count > 0 ? scores.Average() : 0,
                    FulfilledPercent = scores.Count > 0 ? fulfilled * 100.0 / scores.Count : 0,
                    RunCount = scores.Count
                });
                _batchProgress++;
                StateHasChanged();
            }
        }
        finally
        {
            _batchRunning = false;
            JobsSvc.Complete(jobId);
            StateHasChanged();
        }
    }
}
