@page "/prompts/edit"
@inject PromptRegistryService Registry
@inject ExportService Export
@inject IDialogService DialogSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(_prompt?.Name ?? "Edit prompt") — ReviDotNet Forge</PageTitle>

@if (_prompt is null)
{
    <MudAlert Severity="Severity.Warning">
        Prompt <code>@Name</code> not found.
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/prompts">Back to Registry</MudButton>
    </MudAlert>
}
else
{
    <div class="d-flex align-center mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/prompts" />
        <div class="ml-2">
            <MudText Typo="Typo.h4">@_prompt.Name</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">v@(_prompt.Version) · @(_dirty ? "modified" : "saved")</MudText>
        </div>
        <MudSpacer />
        <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary">
            <MudButton StartIcon="@Icons.Material.Filled.PlayArrow"
                       Href="@($"/test?prompt={Uri.EscapeDataString(_prompt.Name ?? string.Empty)}")">
                Test
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.TrendingUp"
                       Href="@($"/optimize?prompt={Uri.EscapeDataString(_prompt.Name ?? string.Empty)}")">
                Optimize
            </MudButton>
        </MudButtonGroup>
        <MudButton Class="ml-2"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.FileDownload"
                   OnClick="@ExportPmt">
            Export
        </MudButton>
        <MudButton Class="ml-2"
                   Variant="Variant.Filled"
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@(!_dirty || _saving)"
                   OnClick="@PromptToSave">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
    </div>

    <MudPaper Class="pa-4" Elevation="1">
        <MudTabs Elevation="0" Rounded="true">

            <MudTabPanel Text="Content" Icon="@Icons.Material.Filled.Edit">
                <div class="pa-2">
                    <MudTextField @bind-Value="_system"
                                  Label="System Message"
                                  Lines="6"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="mb-3"
                                  Immediate="true"
                                  OnDebounceIntervalElapsed="@((string _) => MarkDirty())"
                                  DebounceInterval="300" />
                    <MudTextField @bind-Value="_instruction"
                                  Label="Instruction (use {InputName} placeholders)"
                                  Lines="10"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="mb-3"
                                  Immediate="true"
                                  OnDebounceIntervalElapsed="@((string _) => MarkDirty())"
                                  DebounceInterval="300" />
                    <MudTextField @bind-Value="_schema"
                                  Label="Schema (JSON / regex / GBNF as appropriate)"
                                  Lines="5"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Immediate="true"
                                  OnDebounceIntervalElapsed="@((string _) => MarkDirty())"
                                  DebounceInterval="300" />
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Settings" Icon="@Icons.Material.Filled.Settings">
                <div class="pa-2">
                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudCheckBox @bind-Value="_requestJson" Label="request-json" Color="Color.Primary" CheckedChanged="@((bool _) => MarkDirty())" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudCheckBox @bind-Value="_chainOfThought" Label="chain-of-thought" Color="Color.Primary" CheckedChanged="@((bool _) => MarkDirty())" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudCheckBox @bind-Value="_requireValidOutput" Label="require-valid-output" Color="Color.Primary" CheckedChanged="@((bool _) => MarkDirty())" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudCheckBox @bind-Value="_useSearchGrounding" Label="use-search-grounding" Color="Color.Primary" CheckedChanged="@((bool _) => MarkDirty())" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect T="GuidanceSchemaType?"
                                       Value="_guidance"
                                       ValueChanged="@(v => { _guidance = v; MarkDirty(); })"
                                       Label="guidance-schema-type"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Clearable="true">
                                <MudSelectItem T="GuidanceSchemaType?" Value="@((GuidanceSchemaType?)null)">(default)</MudSelectItem>
                                <MudSelectItem T="GuidanceSchemaType?" Value="@((GuidanceSchemaType?)GuidanceSchemaType.JsonAuto)">json-auto</MudSelectItem>
                                <MudSelectItem T="GuidanceSchemaType?" Value="@((GuidanceSchemaType?)GuidanceSchemaType.JsonManual)">json</MudSelectItem>
                                <MudSelectItem T="GuidanceSchemaType?" Value="@((GuidanceSchemaType?)GuidanceSchemaType.RegexAuto)">regex-auto</MudSelectItem>
                                <MudSelectItem T="GuidanceSchemaType?" Value="@((GuidanceSchemaType?)GuidanceSchemaType.RegexManual)">regex</MudSelectItem>
                                <MudSelectItem T="GuidanceSchemaType?" Value="@((GuidanceSchemaType?)GuidanceSchemaType.GNBFAuto)">gbnf-auto</MudSelectItem>
                                <MudSelectItem T="GuidanceSchemaType?" Value="@((GuidanceSchemaType?)GuidanceSchemaType.GNBFManual)">gbnf</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6"><MudNumericField T="int?" Value="_maxTokens" ValueChanged="@(v => { _maxTokens = v; MarkDirty(); })" Label="max-tokens" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="int?" Value="_timeout" ValueChanged="@(v => { _timeout = v; MarkDirty(); })" Label="timeout (s)" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="int?" Value="_retryAttempts" ValueChanged="@(v => { _retryAttempts = v; MarkDirty(); })" Label="retry-attempts" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="int?" Value="_fewShot" ValueChanged="@(v => { _fewShot = v; MarkDirty(); })" Label="few-shot-examples" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="int?" Value="_bestOf" ValueChanged="@(v => { _bestOf = v; MarkDirty(); })" Label="best-of" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" /></MudItem>
                        <MudItem xs="6"><MudTextField Value="_filter" ValueChanged="@((string v) => { _filter = v; MarkDirty(); })" Label="filter" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                        <MudItem xs="6"><MudTextField Value="_minTier" ValueChanged="@((string v) => { _minTier = v; MarkDirty(); })" Label="min-tier (A/B/C)" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                        <MudItem xs="6"><MudTextField Value="_completionType" ValueChanged="@((string v) => { _completionType = v; MarkDirty(); })" Label="completion-type" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                        <MudItem xs="6"><MudTextField Value="_retryPrompt" ValueChanged="@((string v) => { _retryPrompt = v; MarkDirty(); })" Label="retry-prompt" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    </MudGrid>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Tuning" Icon="@Icons.Material.Filled.Tune">
                <div class="pa-2">
                    <MudGrid Spacing="2">
                        <MudItem xs="6"><MudNumericField T="float?" Value="_temperature" ValueChanged="@(v => { _temperature = v; MarkDirty(); })" Label="temperature" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Step="0.05F" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="float?" Value="_topP" ValueChanged="@(v => { _topP = v; MarkDirty(); })" Label="top-p" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Step="0.05F" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="int?" Value="_topK" ValueChanged="@(v => { _topK = v; MarkDirty(); })" Label="top-k" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="float?" Value="_minP" ValueChanged="@(v => { _minP = v; MarkDirty(); })" Label="min-p" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Step="0.05F" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="float?" Value="_presence" ValueChanged="@(v => { _presence = v; MarkDirty(); })" Label="presence-penalty" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Step="0.05F" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="float?" Value="_frequency" ValueChanged="@(v => { _frequency = v; MarkDirty(); })" Label="frequency-penalty" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Step="0.05F" /></MudItem>
                        <MudItem xs="6"><MudNumericField T="float?" Value="_repetition" ValueChanged="@(v => { _repetition = v; MarkDirty(); })" Label="repetition-penalty" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Step="0.05F" /></MudItem>
                    </MudGrid>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Source preview" Icon="@Icons.Material.Filled.Code">
                <div class="pa-2">
                    <RconfigSource Text="@SerializeCurrent()" />
                </div>
            </MudTabPanel>

        </MudTabs>
    </MudPaper>
}

@code {
    [SupplyParameterFromQuery] public string? Name { get; set; }

    private Prompt? _prompt;
    private bool _dirty;
    private bool _saving;

    // Content
    private string _system = "";
    private string _instruction = "";
    private string _schema = "";

    // Settings
    private bool _requestJson;
    private bool _chainOfThought;
    private bool _requireValidOutput;
    private bool _useSearchGrounding;
    private GuidanceSchemaType? _guidance;
    private int? _maxTokens;
    private int? _timeout;
    private int? _retryAttempts;
    private int? _fewShot;
    private int? _bestOf;
    private string _filter = "";
    private string _minTier = "";
    private string _completionType = "";
    private string _retryPrompt = "";

    // Tuning
    private float? _temperature;
    private float? _topP;
    private int? _topK;
    private float? _minP;
    private float? _presence;
    private float? _frequency;
    private float? _repetition;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(Name)) return;
        _prompt = Registry.GetByName(Name);
        if (_prompt is null) return;
        Load(_prompt);
    }

    private void Load(Prompt p)
    {
        _system = p.System ?? "";
        _instruction = p.Instruction ?? "";
        _schema = p.Schema ?? "";
        _requestJson = p.RequestJson ?? false;
        _chainOfThought = p.ChainOfThought ?? false;
        _requireValidOutput = p.RequireValidOutput ?? false;
        _useSearchGrounding = p.UseSearchGrounding ?? false;
        _guidance = p.GuidanceSchema;
        _maxTokens = p.OutputBudget;
        _timeout = p.Timeout;
        _retryAttempts = p.RetryAttempts;
        _fewShot = p.FewShotExamples;
        _bestOf = p.BestOf;
        _filter = p.Filter ?? "";
        _minTier = p.MinTier ?? "";
        _completionType = p.CompletionType ?? "";
        _retryPrompt = p.RetryPrompt ?? "";
        _temperature = p.Temperature;
        _topP = p.TopP;
        _topK = p.TopK;
        _minP = p.MinP;
        _presence = p.PresencePenalty;
        _frequency = p.FrequencyPenalty;
        _repetition = p.RepetitionPenalty;
        _dirty = false;
    }

    private void MarkDirty()
    {
        if (!_dirty) { _dirty = true; StateHasChanged(); }
    }

    private void ApplyEdits()
    {
        if (_prompt is null) return;
        _prompt.System = _system;
        _prompt.Instruction = _instruction;
        _prompt.Schema = _schema;
        _prompt.RequestJson = _requestJson ? true : null;
        _prompt.ChainOfThought = _chainOfThought ? true : null;
        _prompt.RequireValidOutput = _requireValidOutput ? true : null;
        _prompt.UseSearchGrounding = _useSearchGrounding ? true : null;
        _prompt.GuidanceSchema = _guidance;
        _prompt.OutputBudget = _maxTokens;
        _prompt.Timeout = _timeout;
        _prompt.RetryAttempts = _retryAttempts;
        _prompt.FewShotExamples = _fewShot;
        _prompt.BestOf = _bestOf;
        _prompt.Filter = string.IsNullOrWhiteSpace(_filter) ? null : _filter;
        _prompt.MinTier = string.IsNullOrWhiteSpace(_minTier) ? null : _minTier;
        _prompt.CompletionType = string.IsNullOrWhiteSpace(_completionType) ? null : _completionType;
        _prompt.RetryPrompt = string.IsNullOrWhiteSpace(_retryPrompt) ? null : _retryPrompt;
        _prompt.Temperature = _temperature;
        _prompt.TopP = _topP;
        _prompt.TopK = _topK;
        _prompt.MinP = _minP;
        _prompt.PresencePenalty = _presence;
        _prompt.FrequencyPenalty = _frequency;
        _prompt.RepetitionPenalty = _repetition;
    }

    private string SerializeCurrent()
    {
        if (_prompt is null) return "";
        ApplyEdits();
        return PromptRegistryService.SerializePrompt(_prompt);
    }

    private async Task PromptToSave()
    {
        if (_prompt is null) return;
        var parameters = new DialogParameters
        {
            ["Message"] = $"Save changes to '{_prompt.Name}'?",
            ["Detail"] = "Saving will overwrite the .pmt file on disk and archive the prior version under .history.",
            ["ConfirmLabel"] = "Save",
        };
        var dialog = await DialogSvc.ShowAsync<ConfirmDialog>("Confirm save", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        await DoSave();
    }

    private async Task DoSave()
    {
        if (_prompt is null) return;
        _saving = true;
        StateHasChanged();
        try
        {
            ApplyEdits();
            Registry.Save(_prompt);
            _dirty = false;
            Snackbar.Add($"Saved {_prompt.Name}", Severity.Success);
            // Re-load from registry in case version was bumped or schema was normalized.
            _prompt = Registry.GetByName(_prompt.Name ?? string.Empty);
            if (_prompt is not null) Load(_prompt);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExportPmt()
    {
        if (_prompt is null) return;
        ApplyEdits();
        var content = PromptRegistryService.SerializePrompt(_prompt);
        var safeName = (_prompt.Name ?? "prompt").Replace('/', '_').Replace('\\', '_');
        await Export.DownloadTextAsync($"{safeName}.pmt", content, "text/plain");
    }
}
