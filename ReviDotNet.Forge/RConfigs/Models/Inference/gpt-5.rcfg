[[general]]
name = gpt-5
enabled = true
model-string = gpt-5
provider-name = openai

[[settings]]
tier = A
context-window = 400000
# Reasoning models require max_completion_tokens (not max_tokens) on Chat Completions.
max-token-type = MaxCompletionTokens
# Default thinking amount; a prompt overrides it, an unset prompt inherits it, `none` disables thinking.
# gpt-5 reasoning_effort accepts minimal/low/medium/high. The common `minimal` maps to it natively; `max`
# caps at `high` because OpenAI has no level above high.
thinking = high
thinking-conversion-minimal = minimal
thinking-conversion-low = low
thinking-conversion-medium = medium
thinking-conversion-high = high
thinking-conversion-max = high

[[override-settings]]
output-budget = 16000

[[override-tuning]]
temperature = 1
frequency-penalty = disabled
presence-penalty = disabled
repetition-penalty = disabled

[[chat-completion]]
system-message = true
prompt-in-system = false
system-in-user = true
prompt-in-user = true
