[[general]]
name = gpt-5.6-luna
enabled = true
model-string = gpt-5.6-luna
provider-name = openai

[[settings]]
# Tier B: the efficient high-throughput member of the GPT-5.6 family — the natural pick for
# min-tier B prompts (ModelManager.Find prefers the lowest tier that satisfies the minimum).
tier = B
token-limit = 1000000
cost-per-million-input-tokens = 1.0
cost-per-million-output-tokens = 6.0
# Reasoning models require max_completion_tokens (not max_tokens) on Chat Completions.
max-token-type = MaxCompletionTokens
# High-volume tier — default low reasoning; a prompt's `thinking` overrides it.
thinking = low
# GPT-5.6 reasoning_effort accepts none/low/medium/high/xhigh/max; `minimal` floors to none.
thinking-conversion-minimal = none
thinking-conversion-low = low
thinking-conversion-medium = medium
thinking-conversion-high = high
thinking-conversion-max = max

[[override-settings]]
# Forced max-tokens kept ON PURPOSE for reasoning models — see gpt-5-6-sol.rcfg.
max-tokens = 16000

[[override-tuning]]
temperature = 1
frequency-penalty = disabled
presence-penalty = disabled
repetition-penalty = disabled

[[chat-completion]]
system-message = true
prompt-in-system = false
system-in-user = true
prompt-in-user = true
