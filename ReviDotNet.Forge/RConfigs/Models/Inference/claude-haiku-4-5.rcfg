[[general]]
name = claude-haiku-4-5
enabled = true
model-string = claude-haiku-4-5-20251001
provider-name = claude

[[settings]]
tier = B
context-window = 200000
supports-prompt-completion = true
supports-response-completion = true
# Default: no thinking. A prompt may still request it (Claude supports thinking); add a
# thinking-conversion-* table here first if you enable it as the model default.
thinking = none

[[override-tuning]]
temperature = 1
frequency-penalty = disabled
presence-penalty = disabled
repetition-penalty = disabled

[[chat-completion]]
system-message = true
prompt-in-system = false
system-in-user = true
prompt-in-user = true
